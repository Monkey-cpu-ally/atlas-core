# Backend configuration (optional)
#
# Copy to .env and fill in what you need.
#
# Backend listens on 127.0.0.1:8000 by default when using scripts/dev_backend.sh

# Database (optional; if unset, DB-backed features run in "no database" mode)
# DATABASE_URL=postgresql://user:pass@localhost:5432/atlas

# OpenAI / OpenAI-compatible (optional; if unset, AI responses/images will return "AI not configured")
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Alternate integration-prefixed vars (supported by some modules)
# AI_INTEGRATIONS_OPENAI_API_KEY=...
# AI_INTEGRATIONS_OPENAI_BASE_URL=...

# Optional: used by update engine
# ATLAS_VERSION=0.3.3
