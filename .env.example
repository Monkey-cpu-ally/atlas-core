# Copy this file to .env and fill in real values.
# Never commit your real .env file.

# Preferred standard OpenAI variables
OPENAI_API_KEY=sk-...
# Optional: custom OpenAI-compatible endpoint (leave empty for OpenAI default)
OPENAI_BASE_URL=

# Backward-compatible aliases used by parts of this codebase
# If you only set OPENAI_API_KEY, the app will still work.
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
