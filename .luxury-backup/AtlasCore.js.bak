export const getProjectsByPhase = (phase) => {
  const allProjects = [
    ...AI_PERSONAS.ajani.projects.map(p => ({ ...p, ai: 'ajani' })),
    ...AI_PERSONAS.minerva.projects.map(p => ({ ...p, ai: 'minerva' })),
    ...AI_PERSONAS.hermes.projects.map(p => ({ ...p, ai: 'hermes' }))
  ];
  return allProjects.filter(p => p.phase === phase);
};

export const getProjectsByAI = (aiKey) => {
  if (aiKey === 'trinity') {
    return [
      ...AI_PERSONAS.ajani.projects.map(p => ({ ...p, ai: 'ajani' })),
      ...AI_PERSONAS.minerva.projects.map(p => ({ ...p, ai: 'minerva' })),
      ...AI_PERSONAS.hermes.projects.map(p => ({ ...p, ai: 'hermes' }))
    ];
  }
  return AI_PERSONAS[aiKey]?.projects.map(p => ({ ...p, ai: aiKey })) || [];
};

export const getAllProjects = () => {
  return [
    ...AI_PERSONAS.ajani.projects.map(p => ({ ...p, ai: 'ajani' })),
    ...AI_PERSONAS.minerva.projects.map(p => ({ ...p, ai: 'minerva' })),
    ...AI_PERSONAS.hermes.projects.map(p => ({ ...p, ai: 'hermes' }))
  ];
};
