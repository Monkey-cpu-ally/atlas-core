{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ATLAS Desktop",
  "version": "0.1.0",
  "identifier": "com.frazier.atlas.desktop",
  "build": {
    "beforeDevCommand": "yarn start",
    "beforeBuildCommand": "yarn build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../frontend/build"
  },
  "app": {
    "windows": [
      {
        "title": "ATLAS Desktop",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
